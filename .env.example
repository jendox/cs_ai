# =========================
# Core app settings
# =========================
APP_DEBUG=true
INIT_REF_UPDATE=false

# Optional brand overrides are read directly from process env by
# src.libs.zendesk_client.models.Brand.
# BRAND__SUPERSELF_ID=23064017794844
# BRAND__SMARTPARTS_ID=23063999037340
# BRAND__CLEOCORA_ID=23063999037000
# BRAND__SUPPORTED=SUPERSELF

# =========================
# Zendesk
# =========================
ZENDESK__EMAIL=agent@example.com
ZENDESK__TOKEN=replace_me
ZENDESK__SUBDOMAIN=your_subdomain

# =========================
# RabbitMQ
# =========================
RABBITMQ__USER=cs
RABBITMQ__PASSWORD=replace_me
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672

# =========================
# PostgreSQL
# =========================
POSTGRES__USER=cs
POSTGRES__PASSWORD=replace_me
POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__DB=cs

# =========================
# Telegram admin
# =========================
TELEGRAM__BOT_TOKEN=replace_me
TELEGRAM__CHAT_ID=123456789
TELEGRAM__USERNAME=admin_username
TELEGRAM__ENABLED=true
TELEGRAM__MIN_LEVEL=CRITICAL

# =========================
# Web admin
# =========================
WEB__HOST=0.0.0.0
WEB__PORT=8080
WEB__SESSION_SECRET=replace_with_random_64_char_secret
WEB__BOOTSTRAP_USERNAME=admin
WEB__BOOTSTRAP_PASSWORD=replace_with_strong_password
WEB__COOKIE_SECURE=false

# =========================
# LLM
# =========================
LLM__DEFAULT_PROVIDER=google
LLM__GOOGLE__API_KEY=replace_me
LLM__GOOGLE__MODEL=gemini-2.5-flash-lite

# Optional providers. The current app runtime only implements Google client.
# LLM__OPENAI__API_KEY=replace_me
# LLM__OPENAI__MODEL=gpt-4.1-mini
# LLM__ANTHROPIC__API_KEY=replace_me
# LLM__ANTHROPIC__MODEL=anthropic:claude-3.5-sonnet

# =========================
# Amazon SP-API / MCP
# =========================
AMAZON__LWA_CLIENT_ID=replace_me
AMAZON__LWA_CLIENT_SECRET=replace_me
AMAZON__LWA_REFRESH_TOKEN=replace_me

MCP__HOST=localhost
MCP__PORT=9002

# Optional amazon-mcp / advertising settings if the sibling MCP service needs them.
# AMAZON__LWA_CLIENT_SECRET_ROTATION_DEADLINE=YYYY-MM-DD
# AMAZON__ADS_LWA_CLIENT_ID=replace_me
# AMAZON__ADS_LWA_CLIENT_SECRET=replace_me
# AMAZON__ADS_LWA_REFRESH_TOKEN=replace_me
# AMAZON__ADS_US_LWA_REFRESH_TOKEN=replace_me
# AMAZON__EU_MERCHANT_TOKEN=replace_me
# AMAZON__ENABLE_LWA_TOKEN_PERSISTENCE=false
