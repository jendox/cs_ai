# =========================
# Core app settings (cs)
# =========================
APP_DEBUG=false
INIT_REF_UPDATE=false

BRAND__CLEOCORA_ID=your_id
BRAND__SMARTPARTS_ID=your_id
BRAND__SUPERSELF_ID=your_id
BRAND__SUPPORTED=list_of_supported_brand_names

ZENDESK__EMAIL=agent@example.com
ZENDESK__TOKEN=replace_me
ZENDESK__SUBDOMAIN=your_subdomain

RABBITMQ__USER=cs
RABBITMQ__PASSWORD=replace_with_strong_password
RABBITMQ__HOST=rabbitmq
RABBITMQ__PORT=5672

POSTGRES__USER=cs
POSTGRES__PASSWORD=replace_with_strong_password
POSTGRES__HOST=postgres
POSTGRES__PORT=5432
POSTGRES__DB=cs

TELEGRAM__BOT_TOKEN=replace_me
TELEGRAM__CHAT_ID=123456789
TELEGRAM__USERNAME=admin_username
TELEGRAM__ENABLED=true
TELEGRAM__MIN_LEVEL=ERROR

WEB__HOST=0.0.0.0
WEB__PORT=8080
WEB__SESSION_SECRET=replace_with_random_64_char_secret
WEB__BOOTSTRAP_USERNAME=admin
WEB__BOOTSTRAP_PASSWORD=replace_with_strong_password
WEB__COOKIE_SECURE=true

LLM__GOOGLE__API_KEY=replace_me
LLM__GOOGLE__MODEL=gemini-2.5-flash-lite
LLM__DEFAULT_PROVIDER=google

MCP__HOST=amazon-mcp
MCP__PORT=9002

# Required by cs settings model:
AMAZON__LWA_CLIENT_ID=replace_me
AMAZON__LWA_CLIENT_SECRET=replace_me
AMAZON__LWA_REFRESH_TOKEN=replace_me

# =========================
# amazon-mcp extra settings
# =========================
AMAZON__EU_MERCHANT_TOKEN=replace_me
AMAZON__ENABLE_LWA_TOKEN_PERSISTENCE=true

# =========================
# Docker Hub images/tags
# =========================
CS_IMAGE=yourdockerhub/cs-app
CS_TAG=latest
MCP_IMAGE=yourdockerhub/amazon-mcp
MCP_TAG=latest
